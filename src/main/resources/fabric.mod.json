{
	"schemaVersion": 1,
	"id": "better-trackpad",
	"version": "${version}",
	"name": "Better Trackpad",
	"description": "Remaps trackpad gestures into easier left, right, and middle clicks. Fully rebindable via Mod Menu.",
	"authors": [
		"proxsyi"
	],
	"contact": {
		"homepage": "https://github.com/proxsyi/Better-Trackpad",
		"issues": "https://github.com/proxsyi/Better-Trackpad/issues",
		"sources": "https://github.com/proxsyi/Better-Trackpad"
	},
	"license": "LicenseRef-All-Rights-Reserved",
	"icon": "assets/better-trackpad/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.proxsyi.bettertrackpad.BetterTrackpad"
		],
			"client": [
			"io.github.proxsyi.bettertrackpad.client.BetterTrackpadClient"
		],
		"modmenu": [
			"io.github.proxsyi.bettertrackpad.client.BetterTrackpadMenuIntegration"
		]
	},
	"suggests": {
		"modmenu": "*",
		"cloth-config": "*"
	},
	"mixins": [
		"better-trackpad.mixins.json",
		{
			"config": "better-trackpad.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}
